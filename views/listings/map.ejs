<!DOCTYPE html>
<html>
<head>
  <title>Dynamic Rental Map</title>


  <style>
    #map {
      height: 500px;
      width: 100%;
      border-radius: 12px;
      margin-top: 10px;
    }

    input {
      width: 300px;
      padding: 8px;
    }

    button {
      padding: 8px 12px;
      cursor: pointer;
    }
  </style>
</head>

<body>

  <input id="locationInput" placeholder="Enter location (e.g. Malibu, California)" />
  <button onclick="showLocation()">Add Post</button>

  <div id="map"></div>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
