<% layout('/layouts/boilerplate') %>


    <div class="row">
    <div class="col-10 offset-1">

    
    <h3>Listing Details</h3>
<div>
    <div class="show-cards col-8" style="width: 18rem;">
      <img src="<%= post.image.url %>" class="card-img-top card-shows" alt="...">

  <div class="card-body">
    <br>                                                                                                                                                                                                                                                         
    <i class="card-text">
      <p><%= post.owner?.[0]?.username || "Unknown Owner" %></p>
    </i>
    
    <h5 class="card-title"><%=post.title%></h5>
    <p class="card-text"><%=post.description%></p>
  </div>
</div>
   
    <ul class="show-list">
        <% if (post.price) { %>
    <li><p> Price : ₹ <%= post.price.toLocaleString("en-IN") %></p></li>
<% } else { %>
    <li><p> Price : Not specified</p></li>
<% } %>

        <li><p> Location : <%=post.location%></p></li>
        <li> <p> country : <%=post.country%></p></li>
    </ul>
   <br>
   <% if (currentUser && post.owner[0]._id.equals(currentUser._id)) { %>
 <div class=" btns">
    <a href="/listing/<%=post._id%>/update" class="btn btn-dark col-1 edit ">Edit</a>
    <form class="show-btn"method="POST" action="/listing/<%=post._id%>?_method=DELETE">
        <button class="btn btn-dark offset-4">DELETE</button>
    </form>
       
    
    <br>
   
        </div>
  <%}%>
        <hr>

        <% if (currentUser) { %>
        <div class="col-8 offset-3">
          <h4>Leave Review</h4>
        
          <form method="POST" action="/listing/<%=post._id%>/review" novalidate class="needs-validation">
            <div class="mb-3 mt-3">
              <label for="rating" class="form-label m">Rating</label>

            </div>
            <fieldset class="starability-basic">
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
            
            <div class="mb-3 mt-3">
              <label for="comment" class="form-label">Comment</label>
              <textarea name="review[comment]" id="comment" cols="30" rows="3" class="form-control" required></textarea>
            </div>
            <button class="bt btn-outline-dark">Submit</button>
          </form>
          <form></form>
        </div>
        <%}%>
        <hr>

 <%for(let i=0;i<post.reviews.length;i++){%> 

 <div class="review-card"> 
  <h5 class="card-title"><%=post.reviews[i].author.username%></h5>
    <h3 style="color:black"><%= post.title %></h3>
    <h5 style="color:black">Comment: <%= post.reviews[i].comment %></h5>
    <p class="starability-result" data-rating="<%=post.reviews[i].rating %>">
        </p>
   
   

    <form method="POST" action="/listing/<%=post._id%>/review/<%=post.reviews[i]._id%>?_method=DELETE"> 
      <button>Delete</button>
    </form>
</div>

<%}%> 
<div id="map"></div>

 <%- include("../includes/footer.ejs") %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/validation.js"></script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

</body>
</html>


